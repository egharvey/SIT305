<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DetailsFragment">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/outline_arrow_back_ios_24"
        android:backgroundTint="@color/transparent"
        android:layout_margin="35dp"/>

    <ImageButton
        android:id="@+id/btn_saveBookmark"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/outline_bookmark_add_24"
        android:backgroundTint="@color/transparent"
        android:layout_margin="35dp"
        android:layout_gravity="end"/>

    <ImageView
        android:id="@+id/headerImage"
        android:layout_width="wrap_content"
        android:layout_height="150dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_launcher_background"
        android:contentDescription="Story header image"
        android:layout_marginTop="80dp"/>

    <TextView
        android:id="@+id/storyTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="240dp"
        android:layout_marginHorizontal="10dp"
        android:text="Hello"
        android:textStyle="bold"
        android:textSize="25sp"
        android:textColor="@color/black"/>

    <TextView
        android:id="@+id/storyDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:layout_marginTop="295dp"
        android:layout_marginHorizontal="10dp"
        android:text="Hello"
        />

    <TextView
        android:id="@+id/tv_related"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="445dp"
        android:layout_marginHorizontal="10dp"
        android:textSize="23sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:text="Related Stories"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_related"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="475dp"
        android:layout_marginHorizontal="20dp"/>
</FrameLayout>